# Optional: Webshare proxy (for fixed/shared outbound IP)
# Either set WEBSHARE_PROXY_SERVER directly (example: http://82.23.96.252:7478)
# or provide host/port below.
WEBSHARE_PROXY_SERVER=
WEBSHARE_PROXY_HOST=
WEBSHARE_PROXY_PORT=
WEBSHARE_PROXY_USERNAME=
WEBSHARE_PROXY_PASSWORD=